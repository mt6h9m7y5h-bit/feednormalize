# --- Local development ---
HOST=0.0.0.0
PORT=3000
RUST_LOG=info

# Docker Compose (docker compose up -d):
# DATABASE_URL=postgres://feednormalize:feednormalize@localhost:5432/feednormalize

# Postgres.app or local Homebrew PostgreSQL (replace USER with your macOS username):
DATABASE_URL=postgres://USER@localhost:5432/feednormalize

# Seeded automatically when api_keys is empty (default: dev-test-api-key)
API_KEY_SEED=dev-test-api-key

# Optional: use Redis for distributed rate limiting (otherwise in-memory)
# REDIS_URL=redis://127.0.0.1:6379

# --- Object storage ---
# local (default): files under ./uploads/ — no extra config needed
# STORAGE_BACKEND=local

# S3-compatible storage (AWS S3, Cloudflare R2, MinIO) for production:
# STORAGE_BACKEND=s3
# S3_BUCKET=your-bucket-name
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com   # R2/MinIO only

# --- Production (Railway / Fly.io / Docker) ---
# Set these in the platform dashboard or secrets — do not commit real values.
# See DEPLOYMENT.md for Railway step-by-step setup.
#
# DATABASE_URL=postgres://user:password@host:5432/feednormalize
# PORT=3000                    # Railway injects PORT automatically — do not hard-code
# HOST=0.0.0.0                 # required for container networking (Dockerfile default)
# RUST_LOG=info                # optional; app defaults to info when unset
# API_KEY_SEED=<strong-random-production-key>   # openssl rand -hex 32
# API_KEY_SEED_NAME=production-default            # optional display name for seeded key
# REDIS_URL=redis://...        # optional distributed rate limiting
# STORAGE_BACKEND=s3
# S3_BUCKET=feednormalize-prod
# S3_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com   # R2/MinIO only
